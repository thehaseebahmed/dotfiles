services:
  resilio-sync:
    image: lscr.io/linuxserver/resilio-sync:latest
    container_name: resilio-sync

    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/Amsterdam

    volumes:
      - ~/volumes/resilio-sync/config:/config
      - ~/volumes/resilio-sync/sync/authenticator:/sync/authenticator
      - ~/volumes/data/media:/sync/data/media
{{- if eq .chezmoi.fqdnHostname "homelab-002" }}
      - /mnt/ssd/immich:/sync/immich
{{- else if eq .chezmoi.fqdnHostname "homelab-003" }}
      - /mnt/ext-hdd-01/immich:/sync/immich
{{- end }} 

    ports:
      - 8888:8888
      - 55555:55555

    restart: unless-stopped
