arch = {
    packages = [
        "bat",
        "chromium",
        "git",
        "github-cli",
        "hplip",
        "kitty",
        "lazygit",
        "nvm",
        { name = "tailscale", hooks = { after_sync = [
            "systemctl",
            "enable",
            "--now",
            "tailscaled",
        ] } },
        "ttf-zed-mono-nerd",
        "vscodium",
        {{ if ne .chezmoi.fqdnHostname "haseebs-sl3" }}
        "lazydocker",
        "podman-compose",
        "podman-docker",
        { name = "podman", hooks = { after_sync = [
            "systemctl",
            "--user",
            "enable",
            "--now",
            "podman.socket",
        ] } },
        "zed",
        {{ end -}}
    ]
}

brew = {
    packages = [
        "anytype",
        "bat",
        "espanso",
        "font-zed-mono-nerd-font",
        "git",
        "figma",
        "lazygit",
        "neovim",
        "nvm",
        "orbstack",
        "podman-desktop",
        "visual-studio-code",
        "zed",
        "zen",
    ]
}

flatpak = {
    packages = [
        "system:app.zen_browser.zen",
        "system:com.bitwarden.desktop"
    ]
}

